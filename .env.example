# Development environment variables for docker-compose.yml
# Copy this file to .env before starting development stack.

# Required: Ollama endpoint used by backend
OLLAMA_BASE_URL=http://localhost:50050

# Optional: frontend build-time API base URL
# Keep empty to use same-origin /api via nginx proxy
VITE_API_BASE_URL=

# Optional: frontend Socket.IO / edge base URL
# Set this when websocket/socket.io traffic should go to a different host than VITE_API_BASE_URL
VITE_SOCKET_BASE_URL=
